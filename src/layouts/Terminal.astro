---
import { ViewTransitions } from 'astro:transitions';
import { execSync } from 'child_process';
import '../styles/global.css';
import SysNav from '../components/SysNav.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;

let commitCount = '0';
try {
	commitCount = execSync('git rev-list --count HEAD').toString().trim();
} catch {}

let visitorCount = '---';
try {
	const res = await fetch('https://silkymoe.goatcounter.com/counter/%2F.json');
	if (res.ok) {
		const data = await res.json();
		visitorCount = data.count_unique ?? data.count ?? '---';
	}
} catch {}
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Personal architecture and data logs." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ViewTransitions />
		<script data-goatcounter="https://silkymoe.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
		<script is:inline>
			if (localStorage.getItem('high-contrast') === '1') {
				document.documentElement.classList.add('high-contrast');
			}
		</script>
	</head>
	<body>
		<div class={`terminal-grid${Astro.slots.has('right-panel') ? ' has-right-panel' : ''}`}>
			<aside class="sidebar">
				<SysNav version={commitCount} hits={visitorCount} />
			</aside>
			<main class="data-feed">
				<slot />
			</main>
			{Astro.slots.has('right-panel') && (
				<aside class="right-panel">
					<slot name="right-panel" />
				</aside>
			)}
		</div>
	</body>
</html>

<style>
	.terminal-grid {
		display: grid;
		grid-template-columns: 300px 1fr;
		min-height: 100vh;
		padding: 2rem;
		gap: 2rem;
		max-width: 1400px;
		margin: 0 auto;
		position: relative;
		z-index: 10;
	}

	.terminal-grid.has-right-panel {
		grid-template-columns: 300px 1fr 300px;
	}

	.sidebar {
		border-right: 1px solid var(--phosphor);
		padding-right: 1rem;
	}

	@media (min-width: 769px) {
		.sidebar {
			position: sticky;
			top: 2rem;
			max-height: calc(100vh - 4rem);
			overflow-y: auto;
		}

		.right-panel {
			position: sticky;
			top: 2rem;
			max-height: calc(100vh - 4rem);
			overflow-y: auto;
		}
	}

	.right-panel {
		border-left: 1px solid var(--phosphor);
		padding-left: 1rem;
	}

	.data-feed {
		padding-left: 1rem;
	}

	@media (max-width: 768px) {
		.terminal-grid,
		.terminal-grid.has-right-panel {
			grid-template-columns: 1fr;
			grid-template-rows: auto 1fr;
		}
		.sidebar {
			border-right: none;
			border-bottom: 1px solid var(--phosphor);
			padding-bottom: 1rem;
		}
		.right-panel {
			border-left: none;
			border-top: 1px solid var(--phosphor);
			padding-left: 0;
			padding-top: 1rem;
		}
	}
</style>