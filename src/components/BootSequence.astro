---
const lines = [
  { text: '> [SYS_INIT] Initializing environment...', delay: 0 },
  { text: '> [OK] Kernel modules loaded.', delay: 100 },
  { text: '> [OK] Memory allocation successful.', delay: 200 },
  { text: '> [OK] Connecting to main grid...', delay: 350 },
  { text: '> [OK] Secure channel established.', delay: 500 },
  { text: '> [OK] Filesystem mounted: /home/silky', delay: 650 },
  { text: '', delay: 800 },
  { text: '', delay: 850 },
  { text: 'SYSTEM DIRECTORY OVERRIDE ACTIVE', type: 'header', delay: 900 },
  { text: '> Welcome to the main console.', delay: 1050 },
  { text: '> Type a directory from the sidebar to navigate.', delay: 1200 },
  { text: '> Last login: __LAST_LOGIN__', delay: 1350 },
  { text: '', delay: 1450 },
  { text: '', delay: 1500 },
  { text: '> Awaiting input...', type: 'prompt', delay: 1550 },
];

const serializedLines = JSON.stringify(lines);
---

<section class="boot" data-boot-sequence data-lines={serializedLines}></section>

<script>
  let bootTimers: ReturnType<typeof setTimeout>[] = [];

  function clearBoot() {
    bootTimers.forEach((t) => clearTimeout(t));
    bootTimers = [];
    const boot = document.querySelector('[data-boot-sequence]');
    if (boot) boot.innerHTML = '';
  }

  function runBoot() {
    const boot = document.querySelector('[data-boot-sequence]');
    if (!boot) return;

    const rawLines = boot.getAttribute('data-lines');
    if (!rawLines) return;

    const lines: { text: string; type?: string; delay: number }[] = JSON.parse(rawLines);

    const renderLine = (line: { text: string; type?: string }) => {
      if (line.type === 'header') {
        const heading = document.createElement('h2');
        heading.textContent = line.text;
        boot.appendChild(heading);
        return;
      }

      if (line.text === '') {
        const spacer = document.createElement('div');
        spacer.className = 'spacer';
        spacer.setAttribute('aria-hidden', 'true');
        boot.appendChild(spacer);
        return;
      }

      const paragraph = document.createElement('p');
      if (line.type === 'prompt') paragraph.classList.add('prompt');

      const text =
        line.text === '> Last login: __LAST_LOGIN__'
          ? `> Last login: ${new Date().toUTCString()}`
          : line.text;

      paragraph.append(document.createTextNode(text));

      if (line.type === 'prompt') {
        const cursor = document.createElement('span');
        cursor.className = 'blink';
        cursor.textContent = '_';
        paragraph.append(cursor);
      }

      boot.appendChild(paragraph);
    };

    lines.forEach((line) => {
      bootTimers.push(setTimeout(() => renderLine(line), line.delay));
    });
  }

  // Clear stale timers and DOM before each navigation swap
  document.addEventListener('astro:before-swap', clearBoot);
  // Re-run on initial load and after every view transition
  document.addEventListener('astro:page-load', runBoot);
</script>

<style is:global>
  .boot[data-boot-sequence] {
    display: block;
  }

  .boot[data-boot-sequence] p {
    margin: 0;
    opacity: 0;
    animation: fade-in 0.15s forwards;
  }

  .boot[data-boot-sequence] p + p {
    margin-top: 0.15rem;
  }

  .boot[data-boot-sequence] h2 {
    font-size: 1.3rem;
    font-weight: normal;
    border-bottom: 1px solid var(--phosphor);
    display: block;
    padding-bottom: 0.5rem;
    margin: 0.5rem 0;
    opacity: 0;
    animation: fade-in 0.3s forwards;
  }

  .boot[data-boot-sequence] .prompt {
    opacity: 0;
    animation: fade-in 0.15s forwards;
  }

  .boot[data-boot-sequence] .spacer {
    height: 0.85rem;
  }

  .boot[data-boot-sequence] .blink {
    animation: cursor-blink 1s step-end infinite;
  }

  @keyframes fade-in {
    to {
      opacity: 1;
    }
  }

  @keyframes cursor-blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
</style>