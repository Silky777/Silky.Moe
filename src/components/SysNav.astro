---
interface Props {
  version?: string;
  hits?: string;
}

const { version = '0', hits = '---' } = Astro.props;
---

<div class="nav-container">
  <div class="sys-header">
    <h1><span class="user">guest@sys</span>:<span class="path">~</span>$ cd silky.moe<span class="cursor">_</span></h1>
    <p class="version">v1.{version}</p>
  </div>

  <div class="sys-motd">
    <p>> SYSTEM STATUS: <a class="status-link" href="/status">[ONLINE]</a></p>
    <p>> PGP_MASTER_FP:</p>
    <div class="fingerprint-wrap">
      <p class="fp-line">968F 9FE9 CA23 9F0B 3E0E</p>
      <p class="fp-line">4F5D C4E8 8EF0 AACB BFDB</p>
    </div>
  </div>

  <nav class="directory-list">
    <ul>
      <li><a href="/">./root</a></li>
      <li><a href="/about">./about_me</a></li>
      <li><a href="/logs">./system_logs/</a></li>
      <li><a href="/media">./media_cache/</a></li>
      <li><a href="/pgp_public.asc" target="_blank">./public_key.asc</a></li>
    </ul>
  </nav>

  <div class="sys-status">
    <p>> SYS_CLOCK: <span class="val" id="sys-clock">00:00:00</span></p>
    <p>> UPTIME: <span class="val" id="sys-uptime">0d 0h 0m</span></p>
    <p>> LOAD_AVG: <span class="val">0.42 0.37 0.31</span></p>
    <p>> SESSIONS: <span class="val">1 active</span> (<span class="val">{hits}</span> historic)</p>
    <p>> CONTRAST_MODE: <button id="contrast-toggle" class="contrast-btn" aria-label="Toggle high contrast mode" title="Switch between standard and high contrast display">[STANDARD]</button></p>
  </div>
</div>

<script>
  const DEPLOY_TIME = new Date('2026-04-15T16:23:00Z').getTime();
  let clockInterval: ReturnType<typeof setInterval> | null = null;

  function tick() {
    const clockEl = document.getElementById('sys-clock');
    const uptimeEl = document.getElementById('sys-uptime');
    if (!clockEl || !uptimeEl) return;

    clockEl.textContent = new Date().toLocaleTimeString('en-GB', { hour12: false });

    const diff = Date.now() - DEPLOY_TIME;
    const days = Math.floor(diff / 86400000);
    const hrs = Math.floor((diff % 86400000) / 3600000);
    const mins = Math.floor((diff % 3600000) / 60000);
    uptimeEl.textContent = `${days}d ${hrs}h ${mins}m`;
  }

  function startClock() {
    if (clockInterval) clearInterval(clockInterval);
    tick();
    clockInterval = setInterval(tick, 1000);
  }

  // --- High-contrast toggle ---
  function applyContrast(hc: boolean) {
    document.documentElement.classList.toggle('high-contrast', hc);
    const btn = document.getElementById('contrast-toggle');
    if (btn) btn.textContent = hc ? '[HIGH]' : '[STANDARD]';
  }

  // Re-apply HC class after ViewTransitions swaps the html element
  document.addEventListener('astro:after-swap', () => {
    if (localStorage.getItem('high-contrast') === '1') {
      document.documentElement.classList.add('high-contrast');
    }
  });

  // astro:page-load fires on initial load and after every view transition
  document.addEventListener('astro:page-load', () => {
    startClock();

    // Sync button label to current class (class was applied by anti-FOUC script)
    const hc = document.documentElement.classList.contains('high-contrast');
    const btn = document.getElementById('contrast-toggle');
    if (btn) {
      btn.textContent = hc ? '[HIGH]' : '[STANDARD]';
      btn.addEventListener('click', () => {
        const next = !document.documentElement.classList.contains('high-contrast');
        localStorage.setItem('high-contrast', next ? '1' : '0');
        applyContrast(next);
      });
    }
  });
</script>

<style>
  .nav-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    height: 100%;
  }

  .sys-header h1 {
    font-size: 1rem;
    font-weight: normal;
    margin: 0;
  }

  .cursor {
    animation: blink 1s step-end infinite;
  }

  .version {
    font-size: 0.75rem;
    color: var(--phosphor-muted);
    margin: 0.25rem 0 0;
  }

  .sys-motd {
    font-size: 0.85rem;
    color: var(--phosphor-muted);
    border: 1px dashed var(--phosphor);
    padding: 0.75rem;
    background-color: rgba(10, 8, 5, 0.6);
  }

  .sys-motd p {
    margin: 0 0 0.25rem 0;
  }

  .status-link {
    border-bottom: 1px dashed var(--phosphor);
  }

  .fingerprint-wrap {
    margin-top: 0.5rem;
    padding-left: 0.5rem;
    border-left: 2px solid var(--phosphor);
  }

  .fp-line {
    font-size: 0.7rem;
    letter-spacing: 1px;
    margin: 0 !important;
    line-height: 1.2;
    white-space: nowrap;
  }

  .directory-list ul {
    list-style-type: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .directory-list a {
    display: block;
    padding: 0.25rem 0;
    transition: none;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .sys-status {
    margin-top: auto;
    font-size: 0.75rem;
    color: var(--phosphor-muted);
    border-top: 1px dashed var(--phosphor);
    padding-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .sys-status p {
    margin: 0;
  }

  .sys-status .val {
    opacity: 1;
    color: var(--phosphor);
  }

  .a11y-row {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .contrast-btn {
    background: none;
    border: none;
    font-family: inherit;
    font-size: inherit;
    color: var(--phosphor);
    cursor: pointer;
    padding: 0;
    text-shadow: var(--glow);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .contrast-btn:hover {
    background-color: var(--phosphor);
    color: var(--bg-color);
    text-shadow: none;
    text-decoration: none;
  }
</style>
