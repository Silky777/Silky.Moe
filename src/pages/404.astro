---
import Layout from "../layouts/Layout.astro";
---

<Layout title="~ 404 ~">
  <section class="lost">
    <pre class="ascii" aria-hidden="true">{
`   _____ _____ _____
  |  |  |     |  |  |
  |__   |  |  |__   |
     |__|_____|__|`
    }</pre>
    <h1>you seem lost</h1>
    <p>this page doesn't exist — or maybe it never did.</p>
    <div class="actions">
      <a href="/">← take me home</a>
    </div>
    <p class="sub">error 404 · nothing to see here</p>
  </section>
</Layout>

<style>
  .lost {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
    gap: 1rem;
  }

  .ascii {
    font-family: var(--mono);
    font-size: clamp(0.6rem, 2vw, 1rem);
    color: var(--pink);
    line-height: 1.3;
  }

  h1 {
    font-family: var(--mono);
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 700;
    color: var(--text);
  }

  p {
    font-family: var(--mono);
    font-size: 1rem;
    color: var(--text-muted);
  }

  .actions {
    margin-top: 1rem;
  }

  .actions a {
    font-family: var(--mono);
    font-size: 0.9rem;
    color: var(--cyan);
    text-decoration: none;
    padding: 0.5rem 1.25rem;
    border: 1px dashed var(--cyan);
    border-radius: 2px;
    transition: background 0.2s, color 0.2s;
  }

  .actions a:hover {
    background: var(--cyan);
    color: var(--bg);
  }

  .sub {
    margin-top: 2rem;
    font-size: 0.75rem;
    color: var(--text-muted);
  }
</style>
