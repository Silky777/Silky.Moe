---
import Terminal from "../layouts/Terminal.astro";
---

<Terminal title="~/404_not_found">
  <section class="sys-error">
    <pre class="ascii" aria-hidden="true">{
`      444444444            000000000                444444444  
      4::::::::4          00:::::::::00             4::::::::4  
     4:::::::::4        00:::::::::::::00          4:::::::::4  
    4::::44::::4       0:::::::000:::::::0        4::::44::::4  
   4::::4 4::::4       0::::::0   0::::::0       4::::4 4::::4  
  4::::4  4::::4       0:::::0     0:::::0      4::::4  4::::4  
 4::::4   4::::4       0:::::0     0:::::0     4::::4   4::::4  
4::::444444::::444     0:::::0 000 0:::::0    4::::444444::::444
4::::::::::::::::4     0:::::0 000 0:::::0    4::::::::::::::::4
4444444444:::::444     0:::::0     0:::::0    4444444444:::::444
          4::::4       0:::::0     0:::::0              4::::4  
          4::::4       0::::::0   0::::::0              4::::4  
          4::::4       0:::::::000:::::::0              4::::4  
        44::::::44      00:::::::::::::00             44::::::44
        4::::::::4        00:::::::::00               4::::::::4
        4444444444          000000000                 4444444444`
    }</pre>
    <h1>> [ERR_NOT_FOUND]</h1>
    <p>> Directory or file does not exist in the current tree.</p>
    
    <div class="actions">
      <a href="/">./execute_return_to_root</a>
    </div>
    
    <p class="sub">SYS_CODE: 404 · PROCESS TERMINATED</p>
  </section>
</Terminal>

<style>
  .sys-error {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 2rem 0;
    gap: 1.5rem;
  }

  .ascii {
    font-size: clamp(0.25rem, 1vw, 0.55rem);
    color: var(--phosphor);
    line-height: 1.2;
    max-width: 100%;
    overflow: hidden;
    margin: 0;
  }

  h1 {
    font-size: 1.5rem;
    font-weight: normal;
    margin: 0;
    color: var(--phosphor);
  }

  p {
    margin: 0;
    opacity: 0.85;
  }

  .actions {
    margin-top: 1rem;
  }

  .actions a {
    display: inline-block;
    color: var(--phosphor);
    text-decoration: none;
    padding: 0.5rem 1rem;
    border: 1px solid var(--phosphor);
    transition: none;
  }

  .actions a:hover {
    background: var(--phosphor);
    color: var(--bg-color);
    text-shadow: none;
  }

  .sub {
    margin-top: 2rem;
    font-size: 0.75rem;
    opacity: 0.5;
    border-top: 1px dashed var(--phosphor);
    padding-top: 1rem;
    width: 100%;
    max-width: 400px;
  }
</style>