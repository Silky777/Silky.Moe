# Local signing defaults for npm run sign-log
# Copy this file to .env and adjust as needed.
GPG_SIGNING_KEY=C4E88EF0AACBBFDB

# Defaults used by npm run new-log
BLOG_SIGNER=silky.moe
GPG_FINGERPRINT="968F 9FE9 CA23 9F0B 3E0E 4F5D C4E8 8EF0 AACB BFDB"

# Steam live feed (used by SteamWidget on homepage)
# PUBLIC_STEAM_PROXY_URL should point to your own endpoint returning:
# { currentlyPlaying: { appid, name } | null, recentGames: [{ appid, name, playtime_2weeks, playtime_forever }] }
PUBLIC_STEAM_ID=
PUBLIC_STEAM_PROXY_URL=

# Optional NSFW/content filtering
# Comma-separated appids and keyword fragments (case-insensitive)
PUBLIC_STEAM_BLOCK_APPIDS=250820
PUBLIC_STEAM_BLOCK_WORDS=hentai,nsfw,adult,sex,erotic,lewd
